{
    "name": "aurora/queue",
    "description": "Asynchronous task queue and job processing for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "symfony/messenger": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\Queue\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\Queue\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
